# ============================================================
# Configuración de Entorno (Backend)
# ============================================================
# NOTA: En desarrollo local usando `npm run start:dev`, NO necesitas este archivo, 
# el backend automáticamente usará una base de datos SQLite (dev.db).
#
# Solo necesitas llenar estos datos si quieres correr la app 
# conectada a un PostgreSQL que NO esté ejecutándose por Docker Compose.
# ============================================================

# Entorno
NODE_ENV=development
PORT=3000

# Base de Datos PostgreSQL (Solo para uso sin SQLite)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=sgd_user
DB_PASSWORD=sgd_password
DB_DATABASE=sgd_db

# Cache
REDIS_HOST=localhost
REDIS_PORT=6379
