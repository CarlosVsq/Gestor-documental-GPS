# ============================================================
# SGD - Variables de Entorno
# ============================================================
# Copia este archivo como .env y ajusta los valores.
# En el servidor, este archivo debe estar en:
#   ~/sgd-config/.env
# ============================================================

# --- PostgreSQL ---
POSTGRES_USER=sgd_user
POSTGRES_PASSWORD=dbPassword123
POSTGRES_DB=sgd_db

# --- Conexión Backend → PostgreSQL ---
# (deben coincidir con los valores de arriba)
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=sgd_user
DB_PASSWORD=dbPassword123
DB_DATABASE=sgd_db

# --- Conexión Backend → Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- JWT (Autenticación) ---
JWT_SECRET=cambiar-por-un-secreto-seguro-en-produccion
JWT_EXPIRES_IN=8h

# --- Backend (puerto interno, no se expone al exterior) ---
BACKEND_PORT=3000

# --- Frontend (ÚNICO puerto expuesto al exterior) ---
# Cambia este valor al puerto que tengas habilitado en tu servidor
FRONTEND_PORT=8040
