# ============================================================
# SGD - Variables de Entorno (Arquitectura Microservicios)
# ============================================================
# Copia este archivo como .env y ajusta los valores.
# ============================================================

# --- PostgreSQL ---
POSTGRES_USER=sgd_user
POSTGRES_PASSWORD=dbPassword123
POSTGRES_DB=sgd_db

# --- Conexión Microservicios → PostgreSQL ---
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=sgd_user
DB_PASSWORD=dbPassword123
DB_DATABASE=sgd_db

# --- Redis (Cache) ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- JWT (Autenticación) ---
JWT_SECRET=cambiar-por-un-secreto-seguro-en-produccion
JWT_EXPIRES_IN=8h

# --- API Gateway (puerto interno HTTP) ---
BACKEND_PORT=3000

# --- Frontend (ÚNICO puerto expuesto al exterior) ---
FRONTEND_PORT=8040

# --- Microservicio Requerimientos ---
REQUERIMIENTOS_SERVICE_HOST=ms-requerimientos
REQUERIMIENTOS_SERVICE_PORT=3004

# --- Microservicio Almacenamiento (reemplaza ms-documentos) ---
ALMACENAMIENTO_SERVICE_HOST=ms-almacenamiento
ALMACENAMIENTO_SERVICE_PORT=3003

# --- SeaweedFS ---
SEAWEEDFS_FILER_URL=http://seaweedfs-filer:8888
SEAWEEDFS_MASTER_URL=http://seaweedfs-master:9333

# --- Restricciones de archivos (CONFIGURABLE) ---
# MAX_FILE_SIZE_MB: Tamaño máximo permitido por archivo (en MB)
MAX_FILE_SIZE_MB=50
# ALLOWED_MIME_TYPES: Lista de tipos MIME permitidos (separados por coma)
# Para agregar tipos: añade el MIME aquí y actualiza el validador en el frontend
# Tipos excluidos: DWG, CAD, video/* (por decisión de diseño)
ALLOWED_MIME_TYPES=application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/msword,image/png,image/jpeg,image/gif,image/webp
